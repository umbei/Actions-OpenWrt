# 1. 基础系统配置（x86_64 平台）
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_Generic=y
CONFIG_VMDK_IMAGES=y          # 支持 VMware VMDK 格式
CONFIG_VDI_IMAGES=y           # 支持 VirtualBox VDI 格式
CONFIG_QCOW2_IMAGES=y         # 支持 QEMU QCOW2 格式
CONFIG_GZIP_IMAGES=y          # 压缩镜像
CONFIG_TARGET_IMAGES_GZIP=y
CONFIG_TARGET_KERNEL_PARTSIZE=64  # 内核分区 64M
CONFIG_TARGET_ROOTFS_PARTSIZE=1024 # 根文件系统 1024M
CONFIG_DEFAULT_kernel_full=y   # 完整内核（兼容更多硬件）

# 2. 基础功能组件
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_dnsmasq-full=y  # 完整 dnsmasq（支持更多功能）
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iptables=y
CONFIG_PACKAGE_libustream-wolfssl=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lib-ip=y
CONFIG_PACKAGE_luci-lib-nixio=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-mod-network=y
CONFIG_PACKAGE_luci-mod-status=y
CONFIG_PACKAGE_luci-mod-system=y
CONFIG_PACKAGE_luci-proto-ipv6=y
CONFIG_PACKAGE_luci-proto-ppp=y
CONFIG_PACKAGE_luci-theme-argon=y  # 常用 Argon 主题
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_oscrypto=y
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y
CONFIG_PACKAGE_smartmontools=y
CONFIG_PACKAGE_ssid=y
CONFIG_PACKAGE_swconfig=y
CONFIG_PACKAGE_ttyd=y           # 网页终端
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_zlib=y

# 3. Passwall 全家桶（核心+依赖）
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Shadowsocks=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_ShadowsocksR=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_V2ray=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Trojan=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_SingBox=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Clash=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Hysteria=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y

# 4. SmartDNS（含 LuCI 界面）
CONFIG_PACKAGE_smartdns=y
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y

# 5. Lucky（DDNS/端口转发/域名解析）
CONFIG_PACKAGE_luci-app-lucky=y
CONFIG_PACKAGE_luci-i18n-lucky-zh-cn=y

# 6. Adbyby（广告屏蔽大师）
CONFIG_PACKAGE_luci-app-adbyby-plus=y
CONFIG_PACKAGE_luci-i18n-adbyby-plus-zh-cn=y

# 7. 网络优化组件（Passwall 依赖）
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_gnu-netcat=y
CONFIG_PACKAGE_haproxy=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_microsocks=y
CONFIG_PACKAGE_redsocks2=y
CONFIG_PACKAGE_tcping=y
CONFIG_PACKAGE_udp2raw=y
CONFIG_PACKAGE_v2ray-geodata=y  # V2ray 地理数据库
CONFIG_PACKAGE_xray-geodata=y   # Xray 地理数据库

# 8. 内核优化（可选）
CONFIG_KERNEL_IP_TRANSPARENT_PROXY=y
CONFIG_KERNEL_NETFILTER_NETLINK_QUEUE=y
CONFIG_KERNEL_CRYPTO_AES=y
CONFIG_KERNEL_CRYPTO_CAMELLIA=y
CONFIG_KERNEL_CRYPTO_CHACHA20=y
CONFIG_KERNEL_CRYPTO_GCM=y

# 9. 系统优化
CONFIG_PACKAGE_autocore-x86=y    # x86 自动核心优化
CONFIG_PACKAGE_nano=y           # 文本编辑器
CONFIG_PACKAGE_ntpclient=y      # 网络校时
CONFIG_PACKAGE_irqbalance=y     # 中断平衡（提升多核性能）
CONFIG_PACKAGE_frpc=y           # 内网穿透（可选）
CONFIG_PACKAGE_luci-app-frpc=y
CONFIG_PACKAGE_luci-i18n-frpc-zh-cn=y

# 10. 关闭不必要组件（精简固件）
# CONFIG_PACKAGE_luci-app-accesscontrol is not set
# CONFIG_PACKAGE_luci-app-airplay2 is not set
# CONFIG_PACKAGE_luci-app-ddns is not set  # 用 Lucky 替代
# CONFIG_PACKAGE_luci-app-docker is not set
# CONFIG_PACKAGE_luci-app-frpc is not set  # 如需开启可注释此行
# CONFIG_PACKAGE_luci-app-hd-idle is not set
# CONFIG_PACKAGE_luci-app-nfs is not set
# CONFIG_PACKAGE_luci-app-samba4 is not set
